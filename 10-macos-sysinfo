#!/bin/bash
ASCII_ART_NAME="MacOS"
OUTPUT_IPV6=false
CONFIG_FILE="${HOME}/.macos-motd.conf"

if [[ -f "$CONFIG_FILE" ]]; then
	source "$CONFIG_FILE"
fi

os_type=$(uname)
user=$(whoami)
date=$(date)
if command -v toilet >/dev/null 2>&1; then
	toilet -d /opt/homebrew/share/figlet/fonts -f standard -F metal "$ASCII_ART_NAME"
else
	printf "\x1B[1;36m== %s ==\x1B[0m\n" "$ASCII_ART_NAME"
fi
echo "Welcome, ${user}. It's currently ${date}"

