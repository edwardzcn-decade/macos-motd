# "com.microsoft.OneDrive"
# "com.tencent.meeting"
# "com.microsoft.Outlook"
# "com.valvesoftware.steam"
)


declare -a serviceNames=(
"Chrome"
"ChatGPT"
"Codex"
"Teams"
"Surge"
"Docker"
"MySQL"
"WeChat"
"VS Code"
"iTerm"
"Slack"
"Telegram"
"WhatsApp"
# "Notion"
# "OneDrive"
# "Tencent Meeting"
# "Outlook"
# "Steam"
)

declare -a serviceStatus=()

# Read launchctl once, then match each configured service identifier locally.
launchctl_services=$(launchctl list)
for service in "${services[@]}"
do
	active_status=$(grep -F "$service" <<<"$launchctl_services")
	if [[ ! -z $active_status ]]; then
		serviceStatus+=("active")
	else
		serviceStatus+=("inactive")
	fi
done

echo ""
echo "Services running:"

# Use the longest label so every status column starts in the same place.
nameWidth=0
for name in "${serviceNames[@]}"; do
	if [[ "${#name}" -gt "$nameWidth" ]]; then
		nameWidth="${#name}"
	fi
done

termWidth="${COLUMNS:-80}"
if ! [[ "$termWidth" =~ ^[0-9]+$ ]]; then
	termWidth=80
fi

# Fit as many columns as the terminal can hold, with a readable upper bound.
entryWidth=$((nameWidth + 14))
columns=$((termWidth / entryWidth))
if [[ "$columns" -lt 1 ]]; then
	columns=1
elif [[ "$columns" -gt 4 ]]; then
	columns=4
fi

for i in "${!serviceStatus[@]}"; do
	printf "  %-*s " "$nameWidth" "${serviceNames[$i]}"
	if [[ "${serviceStatus[$i]}" == "active" ]]; then
		printf "\e[32m● %-8s\e[0m" "${serviceStatus[$i]}"
	else
		printf "\e[31m▲ %-8s\e[0m" "${serviceStatus[$i]}"
	fi

	if [[ $(((i + 1) % columns)) -eq 0 || "$i" -eq $((${#serviceStatus[@]} - 1)) ]]; then
		printf "\n"
	else
		printf "  "
	fi
done
