#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STATE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/macos-motd"

boot_id() {
	if [[ "$(uname)" == "Darwin" ]]; then
		sysctl -n kern.boottime 2>/dev/null | awk -F'[=,]' '{gsub(/ /, "", $2); print $2}'
	elif [[ -r /proc/sys/kernel/random/boot_id ]]; then
		cat /proc/sys/kernel/random/boot_id
	else
		uptime | awk '{print $3 $4 $5}'
	fi
}

script_label() {
	local label
	label="$(basename "$1")"
	label="${label#[0-9][0-9]-}"
	printf "%s" "$label" | tr '_-' '  '
}

run_boot_script() {
	local script="$1"
	local label marker current_boot previous_boot output status

	current_boot="$(boot_id)"
	label="$(script_label "$script")"
	marker="$STATE_DIR/$(basename "$script").boot"

	if [[ -n "$current_boot" && -f "$marker" ]]; then
		previous_boot="$(cat "$marker" 2>/dev/null)"
		if [[ "$previous_boot" == "$current_boot" ]]; then
			return 2
		fi
	fi

	mkdir -p "$STATE_DIR"
	output="$("$script" 2>&1)"
	status=$?

	printf "  %-24s " "$label"
	if [[ "$status" -eq 0 ]]; then
		printf "\033[32m● done\033[0m\n"
		printf "%s\n" "$current_boot" > "$marker"
	else
		printf "\033[31m▲ failed\033[0m\n"
		if [[ -n "$output" ]]; then
			printf "%s\n" "$output" | sed 's/^/    /'
		fi
	fi

	return "$status"
}

for script in "$SCRIPT_DIR"/[0-9][0-9]-*; do
	if [[ -f "$script" && -x "$script" ]]; then
		case "$(basename "$script")" in
			9[0-9]-*)
				boot_scripts+=("$script")
				;;
			*)
				"$script"
				;;
		esac
	fi
done

if [[ "${#boot_scripts[@]}" -gt 0 ]]; then
	boot_output="$(
	for script in "${boot_scripts[@]}"; do
		run_boot_script "$script"
	done
	)"
	if [[ -n "$boot_output" ]]; then
		echo ""
		echo "Startup tasks:"
		printf "%s\n" "$boot_output"
	fi
fi
